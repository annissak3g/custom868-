{
    "version": 2,
    "scope": "team_OHrUKs5OeS1mGpkw4FekDHSp",
    "builds": [
        {
            "src": "1/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}