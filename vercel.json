{
    "version": 2,
    "scope": "team_OHrUKs5OeS1mGpkw4FekDHSp",
    "builds": [
        {
            "src": "1/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "1/dist"
            }
        }
    ],
    "env": {
        "VITE_API_URL": "@vite_api_url"
    },
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "https://playbeat-backend.onrender.com/api/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}